{
  "name": "appstore-price-monitor-mvp",
  "version": "0.1.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "description": "MVP collector for App Store app and in-app purchase prices across storefronts.",
  "scripts": {
    "start": "node src/cli.js --config config/monitors.example.json --out outputs/chatgpt-prices",
    "collect": "node src/cli.js --config config/monitors.example.json --out outputs/chatgpt-prices",
    "dev": "node src/server.js --dev --config config/monitors.example.json",
    "build": "tsc -b && vite build",
    "serve": "node src/server.js --config config/monitors.example.json",
    "test": "node --test"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
